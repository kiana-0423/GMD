# Lennard-Jones force field for a Ne-Ar binary mixture.
# Lorentz-Berthelot mixing rules are applied automatically for cross-pairs.
force_field  lj
cutoff       8.5

# Each element specifies epsilon [eV] and sigma [Ang].
element  Ne  epsilon  0.003093  sigma  2.780
element  Ar  epsilon  0.010320  sigma  3.405
